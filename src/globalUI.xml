<!-- Xml UI. See documentation: https://api.tabletopsimulator.com/ui/introUI/ -->

<Defaults>
    <Panel color="#00000000" />
    <Text font="Font" color="#EEEEEE" fontSize="16" outline="#000000" outlineSize="1 1" alignment="MiddleRight" />
    <Text class="sub" color="#AAAAAA" />
    <Text class="head" fontStyle="bold" fontSize="20" />
    <ProgressBar color="#000000AA" showPercentageText="false" />
</Defaults>

<!-- ADMIN: Bounty Board Control -->
<Panel
    visibility="Black"
    width="24"
    height="72"
    rectAlignment="LowerRight"
    offsetXY="-300 175"
    >
    <VerticalLayout>
        <Button
            onClick="toggleGoldBounty">1</Button>
        <Button
            onClick="toggleSilverBounty">2</Button>
        <Button
            onClick="toggleBronzeBounty">3</Button>
    </VerticalLayout>
</Panel>

<!-- ADMIN: Pull Timer Reset -->
<InputField
    id="timeIn"
    visibility="Black"
    width="60"
    height="30"
    rectAlignment="LowerCenter"
    offsetXY="115 70"
    onEndEdit="timeInUpdate"
    characterValidation="Integer"
    placeholder="(sec.)"
    >728</InputField>
<Button
    visibility="Black"
    width="24"
    height="24"
    rectAlignment="LowerCenter"
    offsetXY="170 32"
    onClick="resetPullTimer"
    text="R"
    ></Button>

<!-- BGM & Version -->
<Panel
    height="40"
    width="1000"
    rectAlignment="UpperCenter"
    offsetXY="0 -90"
    >
    <VerticalLayout>
        <Text
            id="playing"
            text="Loading..."
            alignment="MiddleCenter"
            color="#FFFFFFAA"
            fontSize="24"
            ></Text>
        <Text
            text="KNBJ v2.6.2 - Rushed Development"
            alignment="MiddleCenter"
            color="#FFFF33AA"
            ></Text>
    </VerticalLayout>
</Panel>

<!-- Panic Timer -->
<Text
    id="panicText"
    visibility="Black"
    text="60"
    rectAlignment="UpperCenter"
    alignment="MiddleCenter"
    height="40"
    width="300"
    offsetXY="0 -150"
    color="#FF333333"
    fontSize="36"
    ></Text>
<ProgressBar
    id="panicBar"
    visibility="Black"
    percentage="100"
    rectAlignment="UpperCenter"
    height="12"
    width="300"
    offsetXY="0 -185"
    fillImageColor="#FF333333"
    ></ProgressBar>
<Button
    visibility="Black"
    rectAlignment="UpperCenter"
    width="20"
    height="20"
    offsetXY="130 -165"
    onClick="panicToggle">T</Button>
<Button
    visibility="Black"
    rectAlignment="UpperCenter"
    width="20"
    height="20"
    offsetXY="-130 -165"
    onClick="panicReset">R</Button>

<!-- Bottom Bar Clock -->
<Panel
    height="40"
    width="300"
    rectAlignment="LowerCenter"
    offsetXY="0 40"
    >
    <HorizontalLayout>
        <Text
            id="time"
            text="HH:MM:SS"
            alignment="LowerLeft"
            color="#FFFFFFAA"
            fontSize="36"
            ></Text>
        <Text
            id="timer"
            text="(Pull Timer)"
            alignment="LowerRight"
            color="#FFFFFFAA"
            fontSize="24"
            ></Text>
    </HorizontalLayout>
</Panel>
<ProgressBar
    height="12"
    width="300"
    rectAlignment="LowerCenter"
    offsetXY="0 32"
    id="timerBar"
    percentage="100"
    color="#000000AA"
    fillImageColor="#FFFFFFAA"
    ></ProgressBar>

<!-- Bounty Bars -->
<!-- All-time max: 145e29 (31.16 pts) -->
<ProgressBar
    rectAlignment="LowerRight"
    width="250"
    height="8"
    offsetXY="-10 225"
    percentage="100"
    fillImageColor="#ff991199"
    ></ProgressBar>
<ProgressBar
    rectAlignment="LowerRight"
    width="250"
    height="8"
    offsetXY="-10 205"
    percentage="31"
    fillImageColor="#bbbbcc99"
    ></ProgressBar>
<ProgressBar
    rectAlignment="LowerRight"
    width="250"
    height="8"
    offsetXY="-10 185"
    percentage="24"
    fillImageColor="#99551199"
    ></ProgressBar>
<ProgressBar
    rectAlignment="LowerRight"
    width="250"
    height="8"
    offsetXY="-10 120"
    percentage="17"
    fillImageColor="#aaaaaa99"
    ></ProgressBar>
<ProgressBar
    rectAlignment="LowerRight"
    width="250"
    height="8"
    offsetXY="-10 100"
    percentage="15"
    fillImageColor="#aaaaaa99"
></ProgressBar>

<!-- Side Panel -->
