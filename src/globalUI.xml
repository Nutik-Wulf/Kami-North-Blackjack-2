<!-- Xml UI. See documentation: https://api.tabletopsimulator.com/ui/introUI/ -->

<Defaults>
    <Panel color="#00000000" />
    <Text fontStyle="bold" color="#eeeeee" fontSize="18" outline="#000000" outlineSize="2 2" alignment="MiddleRight" />
    <Text class="sub" color="#aaaaaa" />
    <Text class="head" fontSize="22" />
    <ProgressBar color="#00000033" showPercentageText="false" />
</Defaults>

<!-- ADMIN: Bounty Board Control -->
<Panel
    visibility="Black"
    width="32"
    height="96"
    rectAlignment="LowerRight"
    offsetXY="-400 205"
    >
    <VerticalLayout>
        <Button
            onClick="toggleGoldBounty">1</Button>
        <Button
            onClick="toggleSilverBounty">2</Button>
        <Button
            onClick="toggleBronzeBounty">3</Button>
    </VerticalLayout>
</Panel>

<!-- ADMIN: Player bals -->

<!-- BGM & Version -->
<Panel
    height="36"
    width="1000"
    rectAlignment="UpperCenter"
    offsetXY="0 -90"
    >
    <Text
        id="playing"
        text="Loading..."
        alignment="MiddleCenter"
        color="#FFFFFF66"
        fontSize="24"
        ></Text>
</Panel>
<Panel
    height="24"
    width="1000"
    rectAlignment="UpperCenter"
    offsetXY="0 -120"
    >
    <Text
        text="KNBJ v2.5.4a - XMLet's Go Gambling"
        alignment="MiddleCenter"
        color="#FFFF3366"
        ></Text>
</Panel>

        <!-- Bounty Bars -->
