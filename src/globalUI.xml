            color="#ff3333"
            ></Text>
        <Text></Text> <!-- Section Spacer -->
        <Text
            text="BOUNTY BOARD (+1 Extra Pull)"
            class="head"
            ></Text>
        <Text
            text="RECORD: 145e29 (14.5N)"
            fontSize="12"
            ></Text>
        <Text
            id="goldBounty"
            text="(2x) 1st: MiniChris @ 145e29 (14.5N)"
            color="#ff9911"
            ></Text>
        <Text
            id="silverBounty"
            text="2nd: Hyskel @ 355e7 (3.55B)"
