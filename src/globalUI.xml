            ></Text>
        <Text
            text="5th: reilly999 @ 530e2 (53K)"
            class="sub"
            ></Text>
    </VerticalLayout>
</Panel>

<!-- Watermark -->
<Text
    font="Foobar"
    width="500"
    height="50"
    rectAlignment="LowerRight"
    offsetXY="-190 45"
    text="Activate Windows"
    color="#cccccc66"
    fontSize="32"
    fontStyle="normal"
    outlineSize="0 0"
    ></Text>
<Text
    font="Foobar"
    width="500"
    height="50"
    rectAlignment="LowerRight"
    offsetXY="-120 20"
    text="Go to Settings to activate Windows."
    color="#cccccc66"
    fontSize="20"
    fontStyle="normal"
    outlineSize="0 0"
    ></Text>
