            ></Text>
        <Text
            text="6-card Trick (w/ PU): 2:1"
            class="sub"
            ></Text>
        <Text
            text="7-card Trick (w/ PU): 2:1 + 1 Pull"
            class="sub"
            ></Text>
        <Text
            text="Blackjack/5-Cards (w/o PU): 1:1 + 1 Pull"
            ></Text>
        <Text
            text="6-card Trick (w/o PU): 3:1 + 2 Pull"
            ></Text>
        <Text
            text="7-card Trick (w/o PU): 5:1 + 3 Pull"
            ></Text>
