<!-- Xml UI. See documentation: https://api.tabletopsimulator.com/ui/introUI/ -->

<Defaults>
    <Panel color="#00000000" />
    <Text font="Font" color="#eeeeee" fontSize="16" outline="#000000" outlineSize="1 1" alignment="MiddleRight" />
    <Text class="sub" color="#aaaaaa" />
    <Text class="head" fontStyle="bold" fontSize="20" />
    <ProgressBar color="#00000033" showPercentageText="false" />
</Defaults>

<!-- ADMIN: Bounty Board Control -->
<Panel
    visibility="Black"
    width="24"
    height="72"
    rectAlignment="LowerRight"
    offsetXY="-300 175"
    >
    <VerticalLayout>
        <Button
            onClick="toggleGoldBounty">1</Button>
        <Button
            onClick="toggleSilverBounty">2</Button>
        <Button
            onClick="toggleBronzeBounty">3</Button>
    </VerticalLayout>
</Panel>

<!-- BGM & Version -->
<Panel
    height="40"
    width="1000"
    rectAlignment="UpperCenter"
    offsetXY="0 -90"
    >
    <VerticalLayout>
        <Text
            id="playing"
            text="Loading..."
            alignment="MiddleCenter"
            color="#FFFFFF66"
            fontSize="24"
            ></Text>
        <Text
            text="KNBJ v2.6.0 - Toxic"
            alignment="MiddleCenter"
            color="#FFFF3366"
            ></Text>
    </VerticalLayout>
</Panel>

<!-- Bounty Bars -->
<!-- All-time max: 125e25 (27.10 pts) -->
<ProgressBar
    rectAlignment="LowerRight"
    width="250"
    height="8"
    offsetXY="-10 225"
    percentage="95"
    fillImageColor="#ff991199"
    ></ProgressBar>
<ProgressBar
    rectAlignment="LowerRight"
    width="250"
    height="8"
    offsetXY="-10 205"
    percentage="29"
    fillImageColor="#bbbbcc99"
    ></ProgressBar>
<ProgressBar
    rectAlignment="LowerRight"
    width="250"
    height="8"
    offsetXY="-10 185"
    percentage="28"
    fillImageColor="#99551199"
    ></ProgressBar>
<ProgressBar
    rectAlignment="LowerRight"
    width="250"
    height="8"
    offsetXY="-10 120"
    percentage="25"
    fillImageColor="#aaaaaa99"
    ></ProgressBar>
<ProgressBar
    rectAlignment="LowerRight"
    width="250"
    height="8"
    offsetXY="-10 100"
    percentage="18"
    fillImageColor="#aaaaaa99"
></ProgressBar>

